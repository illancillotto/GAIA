PROJECT_NAME=GAIA
APP_ENV=development

POSTGRES_DB=naap
POSTGRES_USER=naap_app
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_VOLUME_NAME=gaia_postgres_data

DATABASE_URL=postgresql+psycopg://naap_app:change_me_postgres_password@postgres:5432/naap

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CREDENTIAL_MASTER_KEY=  # Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ELABORAZIONI_DOCUMENT_STORAGE_PATH=/data/catasto/documents
ELABORAZIONI_CAPTCHA_STORAGE_PATH=/data/catasto/captcha
ELABORAZIONI_WEBSOCKET_POLL_SECONDS=2
ELABORAZIONI_SISTER_PROBE_TIMEOUT_SECONDS=15
BONIFICA_ORISTANESE_DEBUG_STORAGE_PATH=/data/elaborazioni/bonifica-oristanese-debug
ELABORAZIONI_DB_BACKUP_ENABLED=true
ELABORAZIONI_DB_BACKUP_CRON=5 2 * * *
ELABORAZIONI_DB_BACKUP_TIMEZONE=Europe/Rome
ELABORAZIONI_DB_BACKUP_RETENTION_COUNT=5
ELABORAZIONI_DB_BACKUP_LOCAL_DIR=/tmp/gaia-db-backups
ELABORAZIONI_DB_BACKUP_REMOTE_ROOT=/volume1/Backups/GAIA/db
JWT_SECRET_KEY=change_this_secret
JWT_EXPIRE_MINUTES=90
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://gaia.local,http://gaia.local:8080,http://gaia.lan,http://gaia.lan:8080
PDND_CLIENT_ID=
PDND_KID=
PDND_PRIVATE_KEY_PATH=/app/secrets/pdnd/private_key.pem
PDND_PRIVATE_KEY_PEM=
PDND_AUTH_URL=https://auth.interop.pagopa.it/token.oauth2
PDND_CLIENT_ASSERTION_AUDIENCE=auth.interop.pagopa.it/client-assertion
PDND_AUDIENCE=https://interop.pagopa.it/
ANPR_BASE_URL=https://modipa.anpr.interno.it/govway/rest/in/MinInternoPortaANPR-PDND
ANPR_CA_BUNDLE_PATH=/app/secrets/pdnd/sogei-ca-test.pem
ANPR_SSL_VERIFY=true
ANPR_DAILY_CALL_HARD_LIMIT=90
ANPR_JOB_BATCH_SIZE=10
ANPR_JOB_START_HOUR=8
ANPR_JOB_END_HOUR=18
ANPR_JOB_TIMEZONE=Europe/Rome
# opzionale: se omesso il job usa automaticamente l'ultimo anno ruolo disponibile
ANPR_JOB_RUOLO_YEAR=
PDND_FRUITORE_USER_ID=GAIA-CBO
PDND_FRUITORE_USER_LOCATION=GAIA-SRV
PDND_LOA=LOW
PURPOSE_ID_C030=
PURPOSE_ID_C004=
CLIENT_ID=  # Alias legacy: preferire PDND_CLIENT_ID
KID=  # Alias legacy: preferire PDND_KID
PRIVATE_KEY_PATH=/app/secrets/pdnd/private_key.pem  # Alias legacy: preferire PDND_PRIVATE_KEY_PATH
CLIENT_ASSERTION=  # Runtime/legacy: lasciare vuoto

NAS_HOST=192.168.1.2
NAS_PORT=2222
NAS_USERNAME=svc_naap
# `svc_naap` e un account tecnico NAS legacy ancora valido: non rinominarlo automaticamente durante refactor del naming applicativo.
NAS_PASSWORD=change_me
NAS_PRIVATE_KEY_PATH=
NAS_TIMEOUT=10
NAS_DB_BACKUP_ROOT=/volume1/Backups/GAIA/db
NAS_DB_BACKUP_RETENTION_COUNT=14
ANAGRAFICA_NAS_ARCHIVE_ROOT=/volume1/Settore Catasto/ARCHIVIO
UTENZE_NAS_ARCHIVE_ROOT=/volume1/Settore Catasto/ARCHIVIO
UTENZE_DOCUMENT_STORAGE_PATH=/data/anagrafica/documents
NAS_PASSWD_COMMAND=cat /etc/passwd
NAS_GROUP_COMMAND=cat /etc/group
NAS_SHARES_COMMAND=ls /volume1
NAS_ACL_COMMAND_TEMPLATE=/usr/syno/bin/synoacltool -get /volume1/{share}
SYNC_LIVE_MAX_ATTEMPTS=3
SYNC_LIVE_RETRY_DELAY_SECONDS=2
SYNC_LIVE_BACKOFF_MODE=fixed
SYNC_LIVE_BACKOFF_MULTIPLIER=2
SYNC_LIVE_BACKOFF_MAX_DELAY_SECONDS=30
SYNC_LIVE_BACKOFF_JITTER_ENABLED=false
SYNC_LIVE_BACKOFF_JITTER_RATIO=0.2
SYNC_SCHEDULE_ENABLED=false
SYNC_SCHEDULE_INTERVAL_SECONDS=900
SYNC_SCHEDULE_MAX_CYCLES=0
NETWORK_RANGE=192.168.1.0/24
NETWORK_SCAN_ENABLED=true
NETWORK_SCAN_INTERVAL_SECONDS=900
NETWORK_SCAN_PING_TIMEOUT_MS=1000
NETWORK_SCAN_PORTS=22,80,161,443,445,3389
NETWORK_ENRICHMENT_TIMEOUT_SECONDS=1.0
NETWORK_TELEMETRY_ROLLUP_ENABLED=true
NETWORK_TELEMETRY_ROLLUP_CRON=5 * * * *
NETWORK_TELEMETRY_ROLLUP_TIMEZONE=UTC
NETWORK_TELEMETRY_ROLLUP_LOOKBACK_HOURS=6
NETWORK_FIREWALL_RAW_RETENTION_DAYS=14
NETWORK_SOPHOS_SYSLOG_ENABLED=true
NETWORK_SOPHOS_SYSLOG_BIND_HOST=0.0.0.0
NETWORK_SOPHOS_SYSLOG_PORT=5514
NETWORK_SOPHOS_FIREWALL_DEFAULT_NAME=Sophos XGS87
NETWORK_SOPHOS_FIREWALL_MANAGEMENT_IP=
NETWORK_SOPHOS_SNMP_ENABLED=true
NETWORK_SOPHOS_SNMP_HOST=
NETWORK_SOPHOS_SNMP_PORT=161
NETWORK_SOPHOS_SNMP_COMMUNITY=change_me_snmp_community
NETWORK_SOPHOS_SNMP_INTERVAL_SECONDS=300
NETWORK_SOPHOS_SNMP_CUSTOM_OIDS=[]
NETWORK_SNMP_COMMUNITIES=public
NETWORK_SNMP_COMMUNITY_PROFILES=[]
NETWORK_ARP_HELPER_BASE_URL=http://host.docker.internal:9105
NETWORK_GATEWAY_ARP_HOST=
NETWORK_GATEWAY_ARP_PORT=22
NETWORK_GATEWAY_ARP_USERNAME=
NETWORK_GATEWAY_ARP_PASSWORD=
NETWORK_GATEWAY_ARP_PRIVATE_KEY_PATH=
NETWORK_GATEWAY_ARP_COMMAND=ip neigh show {ip}
CODEX_LB_URL=http://host.docker.internal:2455/v1
CODEX_LB_API_KEY=sk-clb-change-me
WIKI_CHAT_MODEL=gpt-5.5
WIKI_TOP_K=5
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.local
BOOTSTRAP_ADMIN_PASSWORD=change_me_admin_password
ANAGRAFICA_DELETE_PASSWORD=  # Password richiesta per cancellare documenti Anagrafica (header X-GAIA-Delete-Password). Vuoto = disabilitato.
UTENZE_DELETE_PASSWORD=  # Alias preferito: password richiesta per cancellare documenti Utenze (header X-GAIA-Delete-Password). Vuoto = disabilitato.

FRONTEND_PORT=3000
FRONTEND_PUBLIC_URL=http://localhost:3000
API_BASE_URL=http://backend:8000
NEXT_PUBLIC_API_BASE_URL=/api
USER_INVITE_EXPIRE_HOURS=72
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=GAIA CED
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

NGINX_PORT=8080
# Mantenere una porta dedicata se sullo stesso host convivono altri stack locali come teti.local o gaia-mobile.local.
# Usare NGINX_PORT=80 solo se GAIA e l'unico servizio esposto o se esiste un reverse proxy condiviso davanti agli stack.

ELABORAZIONI_POLL_INTERVAL_SEC=3
ELABORAZIONI_SISTER_SELECTORS_PATH=
ELABORAZIONI_DEBUG_ARTIFACTS_PATH=/data/catasto/debug
ELABORAZIONI_REPORT_STORAGE_PATH=/data/catasto/reports
ELABORAZIONI_LOG_LEVEL=INFO
CAPTCHA_MAX_OCR_ATTEMPTS=3
CAPTCHA_MANUAL_TIMEOUT_SEC=300
ANTI_CAPTCHA_API_KEY=
ANTI_CAPTCHA_POLL_INTERVAL_SEC=3
ANTI_CAPTCHA_TIMEOUT_SEC=120
STITCH_API_KEY=
BETWEEN_VISURE_DELAY_SEC=5
SESSION_TIMEOUT_SEC=1680
ELABORAZIONI_HEADLESS=true
ELABORAZIONI_DEBUG_BROWSER=false
