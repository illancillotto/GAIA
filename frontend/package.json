{
  "name": "gaia-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "build:clean": "rm -rf .next && next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "lint": "next lint",
    "test": "node --test tests/smoke.test.mjs",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:from-root": "tsc -p ../tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tanstack/react-table": "8.21.3",
    "clsx": "2.1.1",
    "mammoth": "^1.12.0",
    "maplibre-gl": "^4.7.1",
    "maplibre-gl-draw": "^1.6.9",
    "next": "^15.5.18",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-draggable": "4.4.6",
    "react-hook-form": "^7.56.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "2.5.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "22.15.21",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "^15.5.14",
    "postcss": "8.5.10",
    "tailwindcss": "3.4.13",
    "typescript": "5.8.3"
  }
